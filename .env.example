# ── Required secrets ─────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
POSTGRES_PASSWORD=change_me_postgres_password
FCM_SERVER_KEY=your_firebase_server_key_here

